<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Caesar Mumal Gaming Market Place' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar">
    <div class="container">
      <a href="/" class="navbar-brand">
        <span class="logo-icon">🎮</span>
        <span class="logo-text">Caesar Mumal Gaming</span>
      </a>

      <form action="/search" method="GET" class="navbar-search">
        <input type="text" name="q" placeholder="Cari game (contoh: Free Fire)..." value="<%= typeof query !== 'undefined' ? query : '' %>" required>
        <button type="submit">🔍</button>
      </form>

      <button class="menu-toggle" id="menuToggle">☰</button>

      <ul class="navbar-menu" id="navMenu">
        <li style="display: flex; align-items: center;">
          <button class="theme-toggle" id="themeToggle" title="Ganti tema siang/malam" aria-label="Toggle theme">
            <span class="icon sun">☀️</span>
            <span class="icon moon">🌙</span>
          </button>
        </li>
        <li><a href="/">Home</a></li>
        <li><a href="/joki">🏆 Joki</a></li>
        <li><a href="/akun-game">💎 Akun</a></li>
        <li><a href="/seller/marketplace">🛍️ Marketplace</a></li>
        <li><a href="/#games">Games</a></li>
        <% if (user) { %>
          <% if (user.role === 'admin') { %>
            <li><a href="/admin">Dashboard Admin</a></li>
          <% } %>
          <li><a href="/seller" title="Seller Dashboard">💰 Jualan</a></li>
          <li><a href="/auth/profile" class="nav-balance">Rp <%= parseInt(user.balance || 0).toLocaleString('id-ID') %></a></li>
          <li><a href="/auth/logout" style="color: var(--danger);">Logout</a></li>
        <% } else { %>
          <li><a href="/auth/login">Login</a></li>
          <li><a href="/auth/register" class="btn-nav">Daftar</a></li>
        <% } %>
      </ul>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (success && success.length > 0) { %>
    <div class="container">
      <div class="flash flash-success">
        <span>✅</span> <%= success %>
      </div>
    </div>
  <% } %>
  
  <% if (error && error.length > 0) { %>
    <div class="container">
      <div class="flash flash-error">
        <span>⚠️</span> <%= error %>
      </div>
    </div>
  <% } %>

  <!-- Main Content -->
  <main>
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <a href="/" class="navbar-brand mb-2">
            <span class="logo-icon">🎮</span>
            <span class="logo-text">Caesar Mumal Gaming</span>
          </a>
          <p>Platform top up game termurah, tercepat, dan terpercaya di Indonesia. Proses otomatis 24 jam nonstop. Temukan game favoritmu sekarang juga!</p>
        </div>
        <div class="footer-col">
          <h4>Menu Utama</h4>
          <div class="d-flex" style="flex-direction: column; gap: 8px;">
            <a href="/">Beranda</a>
            <a href="/#games">Daftar Game</a>
            <a href="/seller/marketplace">🛍️ Marketplace</a>
            <a href="/joki">🏆 Joki Game</a>
            <a href="/akun-game">💎 Akun Game</a>
            <a href="/auth/login">Login / Daftar</a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Bantuan</h4>
          <div class="d-flex" style="flex-direction: column; gap: 8px;">
            <a href="#">Cara Top Up</a>
            <a href="#">Syarat & Ketentuan</a>
            <a href="#">Hubungi Kami</a>
          </div>
        </div>
        <div class="footer-col">
          <h4>Ikuti Kami</h4>
          <div class="d-flex" style="flex-direction: column; gap: 8px;">
            <a href="#">Instagram</a>
            <a href="#">Facebook</a>
            <a href="#">TikTok</a>
            <a href="#">Discord</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; <%= new Date().getFullYear() %> Caesar Mumal Gaming Market Place. All Rights Reserved.
      </div>
    </div>
  </footer>

  <script>
    // ===== THEME TOGGLE =====
    (function() {
      const themeToggle = document.getElementById('themeToggle');
      const html = document.documentElement;
      
      // Load saved theme
      const savedTheme = localStorage.getItem('cmgm-theme');
      if (savedTheme) {
        html.setAttribute('data-theme', savedTheme);
      } else {
        // Check system preference
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (prefersLight) {
          html.setAttribute('data-theme', 'light');
        }
      }

      // Toggle theme
      if (themeToggle) {
        themeToggle.addEventListener('click', function(e) {
          e.preventDefault();
          const current = html.getAttribute('data-theme');
          const next = current === 'light' ? 'dark' : 'light';
          html.setAttribute('data-theme', next);
          localStorage.setItem('cmgm-theme', next);
          
          // Haptic animation
          this.style.transform = 'scale(0.8)';
          setTimeout(() => { this.style.transform = ''; }, 200);
        });
      }
    })();

    // Navbar scroll effect
    const navbar = document.querySelector('.navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    });

    // Menu toggle for mobile
    document.getElementById('menuToggle').addEventListener('click', function() {
      document.getElementById('navMenu').classList.toggle('active');
    });

    // Auto hide flash messages
    setTimeout(() => {
      const flashes = document.querySelectorAll('.flash');
      flashes.forEach(f => {
        f.style.opacity = '0';
        setTimeout(() => f.remove(), 300);
      });
    }, 5000);
  </script>
</body>
</html>
