<%- include('partials/header') %>
<div class="container">
  <div class="order-detail card">
    <div class="order-header">
      <img src="<%= order.game_logo %>" alt="<%= order.game_name %>" style="width: 80px; height: 80px; border-radius: 16px; margin-bottom: 16px; background: var(--bg-input); padding: 8px;">
      <h1>Pesanan Berhasil Dibuat!</h1>
      <p class="text-secondary">Terima kasih telah berbelanja di Caesar Mumal Gaming.</p>
    </div>
    <div style="text-align: center; margin: 24px 0;">
      <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
    </div>
    <div class="order-info-grid">
      <div class="order-info-item"><div class="label">ID Pesanan</div><div class="value"><%= order.order_id %></div></div>
      <div class="order-info-item"><div class="label">Tanggal Pembelian</div><div class="value"><%= new Date(order.created_at).toLocaleString('id-ID') %></div></div>
      <div class="order-info-item"><div class="label">Game</div><div class="value"><%= order.game_name %></div></div>
      <div class="order-info-item"><div class="label">Produk</div><div class="value"><%= order.product_name %></div></div>
      <div class="order-info-item"><div class="label">ID / Target</div><div class="value"><%= order.game_user_id %><%= order.game_server ? ' (' + order.game_server + ')' : '' %></div></div>
      <div class="order-info-item"><div class="label">Pembayaran</div><div class="value" style="text-transform: capitalize;"><%= order.payment_method %></div></div>
    </div>
    <div class="order-info-item" style="margin-top: 16px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3);">
      <div class="d-flex" style="justify-content: space-between; align-items: center;">
        <span class="label" style="margin: 0;">Total Pembayaran</span>
        <span class="value text-success" style="font-size: 1.2rem;">Rp <%= parseInt(order.total_price).toLocaleString('id-ID') %></span>
      </div>
    </div>
    <% if (order.notes) { %>
      <div class="order-info-item mt-3" style="background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.3);">
        <div class="label text-warning">Catatan Admin</div>
        <div class="value"><%= order.notes %></div>
      </div>
    <% } %>
    <div class="mt-3 text-center">
      <a href="/game/<%= order.game_slug %>" class="btn btn-outline">Beli Lagi</a>
      <a href="/auth/profile" class="btn btn-primary ml-2">Lihat Riwayat</a>
    </div>
  </div>
</div>
<script>const status='<%= order.status %>';if(status==='processing'||status==='pending'){setTimeout(()=>{location.reload()},10000)}</script>
<%- include('partials/footer') %>