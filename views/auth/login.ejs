<%- include('../partials/header') %>
<div class="auth-page">
  <div class="auth-card">
    <h1>Login</h1>
    <p class="auth-subtitle">Masuk ke akun Caesar Mumal Gaming-mu</p>
    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label>Username / Email</label>
        <input type="text" name="username" class="form-control" placeholder="Masukkan username atau email" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" class="form-control" placeholder="Masukkan password" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Masuk Sekarang</button>
    </form>
    <div class="auth-footer">
      Belum punya akun? <a href="/auth/register">Daftar sekarang</a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>