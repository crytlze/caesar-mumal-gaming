<%- include('partials/header') %>
<div class="container">
  <div class="game-detail-header">
    <img src="<%= game.logo %>" alt="<%= game.name %>" class="game-detail-logo">
    <div class="game-detail-info">
      <h1>Top Up <%= game.name %></h1>
      <p><%= game.description || 'Beli top up ' + game.name + ' murah, aman dan terpercaya.' %></p>
    </div>
  </div>
  <div class="d-flex" style="gap: 30px; flex-wrap: wrap; margin-bottom: 50px;">
    <div style="flex: 2; min-width: 300px;">
      <div class="card">
        <div class="card-header"><h3><span style="background: var(--accent); color: white; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 0.8rem; margin-right: 8px;">1</span> Pilih Nominal Top Up</h3></div>
        <div class="product-grid" id="productGrid">
          <% if (products && products.length > 0) { %>
            <% products.forEach(function(p) { %>
              <div class="product-item <%= p.is_promo ? 'promo' : '' %>" data-id="<%= p.id %>" data-price="<%= p.price %>" onclick="selectProduct(this)">
                <% if (p.is_promo) { %><div class="promo-tag">PROMO</div><% } %>
                <div class="product-name"><%= p.name %></div>
                <div class="product-price">Rp <%= parseInt(p.price).toLocaleString('id-ID') %></div>
                <% if (p.original_price) { %><div class="product-original">Rp <%= parseInt(p.original_price).toLocaleString('id-ID') %></div><% } %>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-muted">Produk sedang tidak tersedia.</p>
          <% } %>
        </div>
      </div>
    </div>
    <div style="flex: 1; min-width: 300px;">
      <form action="/order/create" method="POST" id="orderForm">
        <input type="hidden" name="game_id" value="<%= game.id %>">
        <input type="hidden" name="product_id" id="productIdInput" required>
        <div class="card mb-3">
          <div class="card-header"><h3><span style="background: var(--accent); color: white; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 0.8rem; margin-right: 8px;">2</span> Masukkan Data Akun</h3></div>
          <div class="d-flex gap-2">
            <div class="form-group" style="flex: 2;">
              <label><%= game.id_label %></label>
              <input type="text" name="game_user_id" class="form-control" placeholder="<%= game.id_placeholder %>" required>
            </div>
            <% if (game.has_server) { %>
              <div class="form-group" style="flex: 1;">
                <label><%= game.server_label %></label>
                <input type="text" name="game_server" class="form-control" placeholder="<%= game.server_placeholder %>" required>
              </div>
            <% } %>
          </div>
          <small class="text-muted">Pastikan data akun yang dimasukkan sudah benar.</small>
        </div>
        <div class="card">
          <div class="card-header"><h3><span style="background: var(--accent); color: white; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 0.8rem; margin-right: 8px;">3</span> Pilih Pembayaran & Beli</h3></div>
          <div class="form-group">
            <label>Metode Pembayaran</label>
            <select name="payment_method" class="form-control">
              <option value="saldo">Saldo Akun (Otomatis & Tanpa Biaya)</option>
              <option value="qris" disabled>QRIS (Segera Hadir)</option>
            </select>
          </div>
          <div id="orderSummary" style="display: none; margin: 20px 0; padding: 15px; background: rgba(99, 102, 241, 0.1); border-radius: var(--radius-sm); border: 1px solid rgba(99, 102, 241, 0.3);">
            <div class="d-flex" style="justify-content: space-between; margin-bottom: 8px;">
              <span class="text-secondary">Produk:</span>
              <span id="summaryProductName" style="font-weight: 600;">-</span>
            </div>
            <div class="d-flex" style="justify-content: space-between; font-size: 1.2rem; font-weight: 700; color: var(--success); border-top: 1px dashed var(--border); padding-top: 8px;">
              <span>Total:</span>
              <span id="summaryPrice">Rp 0</span>
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg" id="btnSubmit" disabled>
            <%= !user ? 'Login untuk Membeli' : 'Pilih Produk Dahulu' %>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
  const isAuth = <%= user ? 'true' : 'false' %>;
  function selectProduct(element) {
    document.querySelectorAll('.product-item').forEach(el => el.classList.remove('selected'));
    element.classList.add('selected');
    document.getElementById('productIdInput').value = element.getAttribute('data-id');
    const price = parseInt(element.getAttribute('data-price'));
    const productName = element.querySelector('.product-name').innerText;
    document.getElementById('orderSummary').style.display = 'block';
    document.getElementById('summaryProductName').innerText = productName;
    document.getElementById('summaryPrice').innerText = 'Rp ' + price.toLocaleString('id-ID');
    const btn = document.getElementById('btnSubmit');
    if (isAuth) { btn.disabled = false; btn.innerText = 'Beli Sekarang';
    } else { btn.disabled = false; btn.innerText = 'Login untuk Membeli'; document.getElementById('orderForm').action = '/auth/login'; document.getElementById('orderForm').method = 'GET'; }
  }
</script>
<%- include('partials/footer') %>