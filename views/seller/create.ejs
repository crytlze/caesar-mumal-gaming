<%- include('../partials/header') %>
<div class="container" style="max-width: 720px; padding: 40px 0;">
  <a href="/seller" class="btn btn-outline mb-3">← Kembali ke Dashboard</a>
  <div class="card">
    <div class="card-header"><h3>📝 Buat Listing Baru</h3></div>
    <form action="/seller/create" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Kategori <span class="text-danger">*</span></label>
        <select name="category" class="form-control" required id="categorySelect" onchange="toggleCategoryHint()">
          <option value="">-- Pilih Kategori --</option>
          <option value="akun">💎 Jual Akun Game</option>
          <option value="joki">🏆 Jasa Joki</option>
          <option value="topup">🔄 Top Up / Jasa Lainnya</option>
        </select>
        <small class="text-muted" id="categoryHint" style="display: none;">Pilih kategori yang paling sesuai dengan barang/jasa yang kamu jual.</small>
      </div>
      <div class="form-group">
        <label>Nama Game <span class="text-danger">*</span></label>
        <select name="game_name" class="form-control" required>
          <option value="">-- Pilih Game --</option>
          <option value="Mobile Legends">Mobile Legends</option>
          <option value="Free Fire">Free Fire</option>
          <option value="PUBG Mobile">PUBG Mobile</option>
          <option value="Valorant">Valorant</option>
          <option value="Genshin Impact">Genshin Impact</option>
          <option value="Honor of Kings">Honor of Kings</option>
          <option value="Call of Duty Mobile">Call of Duty Mobile</option>
          <option value="FIFA Mobile">FIFA Mobile</option>
          <option value="Apex Legends">Apex Legends</option>
          <option value="Higgs Domino">Higgs Domino</option>
          <option value="Lainnya">Lainnya (tulis di judul/deskripsi)</option>
        </select>
      </div>
      <div class="form-group">
        <label>Judul Iklan <span class="text-danger">*</span></label>
        <input type="text" name="title" class="form-control" required placeholder="Cth: Akun MLBB Mythic Glory 150+ Skin / Joki Push Rank Valorant" maxlength="100">
        <small class="text-muted">Buat judul yang jelas dan menarik biar cepat laku!</small>
      </div>
      <div class="form-group">
        <label>Deskripsi Detail</label>
        <textarea name="description" class="form-control" rows="4" placeholder="Jelaskan detail barang/jasa yang kamu tawarkan. Cth: rank saat ini, jumlah skin, hero yang dimiliki, dll..."></textarea>
      </div>
      <div class="d-flex gap-3">
        <div class="form-group" style="flex: 1;">
          <label>Harga Jual (Rp) <span class="text-danger">*</span></label>
          <input type="number" name="price" class="form-control" required min="1000" step="500" placeholder="Rp">
        </div>
        <div class="form-group" style="flex: 1;">
          <label>Harga Sebelum (Opsional)</label>
          <input type="number" name="original_price" class="form-control" min="0" step="500" placeholder="Rp">
        </div>
      </div>
      <div class="form-group">
        <label>URL Gambar / Screenshot (Opsional)</label>
        <input type="text" name="image_url" class="form-control" placeholder="https://example.com/gambar-akun.jpg">
        <small class="text-muted">Upload gambar ke imgur/ibb lalu tempel link-nya.</small>
      </div>
      <div class="form-group">
        <label>Atau Upload Gambar Langsung (Max 5MB)</label>
        <input type="file" name="image" class="form-control" accept="image/*">
      </div>
      <div class="form-group">
        <label>Kontak yang bisa dihubungi <span class="text-danger">*</span></label>
        <input type="text" name="contact" class="form-control" required placeholder="Username Telegram / WhatsApp / Discord" value="<%= user.username %>">
        <small class="text-muted">Pembeli akan menghubungimu lewat kontak ini.</small>
      </div>
      <div class="d-flex gap-2 mt-3">
        <a href="/seller" class="btn btn-outline flex-1">Batal</a>
        <button type="submit" class="btn btn-primary flex-1 btn-lg">🚀 Terbitkan Listing</button>
      </div>
      <p class="text-center text-muted mt-2" style="font-size: 0.8rem;">⏳ Listing akan tampil setelah diverifikasi admin (maks. 1x24 jam)</p>
    </form>
  </div>
</div>
<script>
  function toggleCategoryHint() {
    const val = document.getElementById('categorySelect').value;
    document.getElementById('categoryHint').style.display = val ? 'block' : 'none';
  }
</script>
<%- include('../partials/footer') %>